{
  "primitives": {
    "red": {
      "100": {
        "$type": "color",
        "$value": "#f00"
      }
    }
  },
  "semantic": {
    "background": {
      "error": {
        "$extensions": {
          "com.figma.scopes": [
            "FRAME_FILL",
            "SHAPE_FILL"
          ],
          "com.figma.hiddenFromPublishing": true
        },
        "$type": "color",
        "$value": "{blue.100}"
      }
    },
    "blue": {
      "100": {
        "$extensions": {
          "com.figma.scopes": [
            "FRAME_FILL",
            "SHAPE_FILL"
          ],
          "com.figma.hiddenFromPublishing": true
        },
        "$type": "color",
        "$value": "#00b0ff"
      }
    },
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Afacad Flux",
        "fontWeight": "Light Italic",
        "fontSize": "{test}",
        "lineHeight": "{OLA}",
        "letterSpacing": "{OLA}",
        "paragraphSpacing": "24",
        "paragraphIndent": "{OLA}",
        "textDecoration": "24",
        "textCase": "24"
      }
    },
    "test": {
      "$extensions": {
        "com.figma.hiddenFromPublishing": false,
        "com.figma.scopes": [
          "FONT_SIZE"
        ]
      },
      "$type": "fontSizes",
      "$value": "244"
    },
    "test 1": {
      "$type": "fontFamilies",
      "$value": "ABeeZee"
    },
    "OLA": {
      "$type": "number",
      "$value": "OLA"
    },
    "H2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{test 1}",
        "fontWeight": "Italic",
        "fontSize": "{OLA}",
        "lineHeight": "{OLA}",
        "letterSpacing": "{OLA}"
      }
    },
    "H4": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{test 1}"
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "primitives",
      "semantic"
    ]
  }
}